{
  "_comment": "ZCode MCP config — add the mnema server to your MCP servers list. Backend defaults to embedded Chroma (offline).",
  "mcpServers": {
    "mnema": {
      "command": "uvx",
      "args": ["mnema-mcp"],
      "env": {
        "MNEMA_BACKEND": "chroma",
        "MNEMA_BACKEND_PATH": "~/.mnema/zcode",
        "MNEMA_EMBEDDING": "local",
        "MNEMA_DEFAULT_SCOPE": "user:me"
      }
    }
  }
}
